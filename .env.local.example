# Telegram: создайте бота через @BotFather и подставьте токен.
TELEGRAM_BOT_TOKEN=replace_with_telegram_bot_token

# Telegram: ID чата/группы, куда отправлять заявки.
TELEGRAM_CHAT_ID=replace_with_telegram_chat_id

# Google Forms: endpoint вида https://docs.google.com/forms/d/e/FORM_ID/formResponse
GOOGLE_FORMS_ENDPOINT=https://docs.google.com/forms/d/e/replace_with_form_id/formResponse

# Google Forms: имена полей из HTML формы, обычно entry.123456789
GOOGLE_FORMS_NAME_FIELD=entry.replace_name_field
GOOGLE_FORMS_PHONE_FIELD=entry.replace_phone_field
GOOGLE_FORMS_MESSAGE_FIELD=entry.replace_message_field
